# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shahmaghz?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# ZarinPal
ZARINPAL_MERCHANT_ID="your-merchant-id"
