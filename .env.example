# ============================================
# Database - Neon (Serverless Postgres)
# ============================================
# Get from: neon.tech → Your Project → Connection Details
# Use "Pooled connection" for DATABASE_URL (has -pooler in hostname)
# Use "Direct connection" for DIRECT_URL (no -pooler)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/shahmaghz?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/shahmaghz?sslmode=require"

# ============================================
# Image Storage - Cloudinary
# ============================================
# Get from: cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# NextAuth
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# ============================================
# ZarinPal (Iranian Payment Gateway)
# ============================================
ZARINPAL_MERCHANT_ID="your-merchant-id"
ZARINPAL_CALLBACK_URL="http://localhost:3000/api/payment/callback"

# ============================================
# Redis (Optional - for caching)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# SMS Provider - Kavenegar (Optional)
# ============================================
KAVENEGAR_API_KEY="your-api-key"
